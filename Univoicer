        ['Común', 'Estabilidad base'],
        ['Raro', 'Carga amplificada'],
        ['Épico', 'Pulso de energía avanzada'],
        ['Legendario', 'Núcleo máximo']
      ];
      viewRarezas.innerHTML = `
        <section class="mock-shell">
          <h2>Rarezas por nivel de energía</h2>
          <div class="mock-row">
            ${levels.map(([name, desc]) => `<article class="mock-box"><h3>${name}</h3><p class="muted">${desc}</p></article>`).join('')}
          </div>
        </section>
      `;
    }

    function renderActoresView() {
      const actors = [...new Set(VIDEOS.map(v => v.actor_de_doblaje).filter(Boolean))].sort();
      const actor = state.actorFocus || actors[0] || null;
      const actorVideos = VIDEOS.filter(v => (v.actor_de_doblaje || 'Sin actor') === actor);
      const actorCharacters = [...new Set(actorVideos.map(v => v.personaje || 'Sin personaje'))];
      const blockedCharacters = state.blockedCharactersByActor[actor] || [];
      const blockedOnly = blockedCharacters.filter(name => !actorCharacters.includes(name));
      viewActores.innerHTML = `
        <section class="mock-shell holo-card">
          <h2>Colección del actor</h2>
          <label>Seleccionar actor
            <select id="actorPicker">
              ${actors.map(name => `<option value="${name}" ${name === actor ? 'selected' : ''}>${name}</option>`).join('') || '<option>Sin actores</option>'}
            </select>
          </label>
          ${actor ? `
            <article class="mock-box">
              <h3>${actor}</h3>
              <p class="muted">Personajes: ${actorCharacters.length} · Videos: ${actorVideos.length}</p>
            </article>
            <div class="mock-row">
              <article class="mock-box">
                <h3>Personajes con saludo</h3>
                <ul>${actorCharacters.map(name => `<li>${name}</li>`).join('') || '<li>Sin personajes con saludo.</li>'}</ul>
              </article>
              <article class="mock-box">
                <h3>Personajes sin saludo (bloqueados)</h3>
                <ul>${blockedOnly.map(item => `<li>${item}</li>`).join('') || '<li>Sin personajes bloqueados.</li>'}</ul>
                <div class="actions">
                  <input id="blockedCharacterInput" type="text" placeholder="Agregar personaje sin saludo">
                  <button id="addBlockedCharacter" class="neon-btn">Agregar bloqueado</button>
                </div>
                <p class="section-note">Al agregar un video para este personaje, se desbloquea automáticamente.</p>
              </article>
            </div>
          ` : '<p class="muted">Sin actores registrados.</p>'}
        </section>
      `;
      document.getElementById('actorPicker')?.addEventListener('change', (event) => {
        state.actorFocus = event.target.value;
        renderActoresView();
      });
      document.getElementById('addBlockedCharacter')?.addEventListener('click', () => {
        if (!actor) return;
        const input = document.getElementById('blockedCharacterInput');
        const characterName = String(input?.value || '').trim();
        if (!characterName) return;
        const withGreeting = getCharactersByActor(actor);
        if (withGreeting.includes(characterName)) {
          input.value = '';
          return;
        }
        const current = state.blockedCharactersByActor[actor] || [];
        state.blockedCharactersByActor[actor] = [...new Set([...current, characterName])];
        saveBlockedCharacters();
        renderActoresView();
      });
    }

    function renderVersionesView() {
      const multiverse = [...new Set(VIDEOS.map(v => v.personaje).filter(Boolean))].slice(0, 8);
      viewVersiones.innerHTML = `
        <section class="mock-shell">
          <h2>Versiones multiverso</h2>
          <ul>
            ${multiverse.map(name => `<li>${name} · Variante Alpha/Beta (mock)</li>`).join('') || '<li>Sin variantes disponibles.</li>'}
          </ul>
          <button>Explorar variantes</button>
        </section>
      `;
    }

    function renderFavoritosView() {
      const favorites = VIDEOS.slice(0, 3);
      viewFavoritos.innerHTML = `
        <section class="mock-shell">
          <h2>Favoritos</h2>
          ${favorites.length
            ? `<ul>${favorites.map(item => `<li>${item.personaje || 'Sin personaje'} · ${item.titulo || 'Sin título'}</li>`).join('')}</ul>`
            : '<p class="muted">No hay elementos prioritarios aún</p>'}
        </section>
      `;
    }

    function renderBuscarView() {
      viewBuscar.innerHTML = `
        <section class="mock-shell" style="min-height: 58vh; place-content: center;">
          <input type="search" style="font-size:1.15rem; padding:16px;" placeholder="placeholder exacto solicitado" aria-label="Búsqueda global">
        </section>
      `;
    }

    function renderStatsView() {
      viewStats.innerHTML = `
        <section class="mock-shell">
          <h2>Estadísticas</h2>
          <div class="mock-row">
            <article class="kpi"><strong>KPI 1</strong><p class="muted">Conversión mock: 24%</p></article>
            <article class="kpi"><strong>KPI 2</strong><p class="muted">Retención mock: 72%</p></article>
            <article class="kpi"><strong>KPI 3</strong><p class="muted">Rareza alta mock: 19%</p></article>
          </div>
          <div class="mock-row">
            <div class="mock-box">Placeholder gráfico de líneas</div>
            <div class="mock-box">Placeholder gráfico de barras</div>
          </div>
        </section>
      `;
    }

    function renderConfigView() {
      viewConfig.innerHTML = `
        <section class="mock-shell">
          <h2>Configuración</h2>
          <div class="mock-row">
            <button>Importar JSON</button>
            <button>Exportar JSON</button>
            <div class="mock-box">
              <p>Tema</p>
              <div class="theme-toggle" aria-hidden="true"></div>
            </div>
          </div>
        </section>
      `;
    }

    function cssSafe(text) {
      return text.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-');
    }

    function startMarathon() {
      const queue = getFilteredUniverseVideos();
      if (!queue.length) return;
      state.marathon.active = true;
      state.marathon.queue = queue;
      state.marathon.position = 0;
      state.selectedVideoId = queue[0].id;
      renderUniverseView();
      updateMarathonLabel();
    }

    function nextInMarathon() {
      if (!state.marathon.active) return;
      if (state.marathon.position >= state.marathon.queue.length - 1) {
        state.marathon.active = false;
        updateMarathonLabel('Maratón finalizado.');
        return;
      }
      state.marathon.position += 1;
      const current = state.marathon.queue[state.marathon.position];
      state.selectedVideoId = current.id;
      renderUniverseView();
      updateMarathonLabel();
    }

    function updateMarathonLabel(override) {
      const el = document.getElementById('marathonState');
      if (!el) return;
      if (override) {
        el.textContent = override;
        return;
      }
      if (state.marathon.active) {
        el.textContent = `Reproduciendo ${state.marathon.position + 1} de ${state.marathon.queue.length}`;
      } else {
        el.textContent = 'Modo Maratón desactivado';
      }
    }

    function attachPlayerEndedHandler() {
      const iframe = document.getElementById('videoPlayer');
      if (!iframe) return;
      const currentUrl = new URL(iframe.src);
      const videoId = currentUrl.pathname.split('/').pop();

      // Fallback simple: avanza cada 12s en modo maratón si no se puede captar evento "ended" del reproductor embebido.
      // Esto mantiene la reproducción encadenada sin interacción adicional tras activar maratón.
      clearTimeout(window.__marathonFallback);
      if (state.marathon.active && videoId) {
        window.__marathonFallback = setTimeout(nextInMarathon, 12000);
      }
    }

    function changeView(next) {
      state.view = next;
      viewInicio.classList.toggle('active', next === 'inicio');
      viewMap.classList.toggle('active', next === 'map');
      viewUniverse.classList.toggle('active', next === 'universe');
      viewIndice.classList.toggle('active', next === 'indice');
      viewMaraton.classList.toggle('active', next === 'maraton');
      viewRarezas.classList.toggle('active', next === 'rarezas');
      viewActores.classList.toggle('active', next === 'actores');
      viewVersiones.classList.toggle('active', next === 'versiones');
      viewAchievements.classList.toggle('active', next === 'achievements');
      viewFavoritos.classList.toggle('active', next === 'favoritos');
      viewBuscar.classList.toggle('active', next === 'buscar');
      viewStats.classList.toggle('active', next === 'stats');
      viewConfig.classList.toggle('active', next === 'config');
      document.querySelectorAll('.sidebar-nav .sidebar-item').forEach(btn => btn.classList.remove('active'));
      const activeNavByView = {
        inicio: navInicio,
        map: navUniverses,
        universe: navUniverses,
        indice: navIndice,
        maraton: navMaraton,
        rarezas: navRarezas,
        actores: navActores,
        versiones: navVersiones,
        achievements: navAchievements,
        favoritos: navFavoritos,
        buscar: navBuscar,
        stats: navStats,
        config: navConfig
      };
      activeNavByView[next]?.classList.add('active');

      if (next === 'inicio') renderInicioView();
      if (next === 'map') renderMapView();
      if (next === 'universe') renderUniverseView();
      if (next === 'achievements') renderAchievementsView();
      if (next === 'indice') renderIndiceView();
      if (next === 'maraton') renderMaratonView();
      if (next === 'rarezas') renderRarezasView();
      if (next === 'actores') renderActoresView();
      if (next === 'versiones') renderVersionesView();
      if (next === 'favoritos') renderFavoritosView();
      if (next === 'buscar') renderBuscarView();
      if (next === 'stats') renderStatsView();
      if (next === 'config') renderConfigView();
    }

    toggleSidebar.onclick = () => {
      appLayout.classList.toggle('sidebar-collapsed');
      toggleSidebar.textContent = appLayout.classList.contains('sidebar-collapsed') ? '➡️ Expandir menú' : '↔️ Colapsar menú';
    };

    navInicio.onclick = () => changeView('inicio');
    navUniverses.onclick = () => changeView(state.universe ? 'universe' : 'map');
    navIndice.onclick = () => changeView('indice');
    navMaraton.onclick = () => changeView('maraton');
    navRarezas.onclick = () => changeView('rarezas');
    navActores.onclick = () => changeView('actores');
    navVersiones.onclick = () => changeView('versiones');
    navAchievements.onclick = () => changeView('achievements');
    navFavoritos.onclick = () => changeView('favoritos');
    navBuscar.onclick = () => changeView('buscar');
    navStats.onclick = () => changeView('stats');
    navConfig.onclick = () => changeView('config');

    state.universeNodes = loadUniverseNodesFromStorage();
    state.blockedCharactersByActor = loadBlockedCharactersFromStorage();
    changeView('map');
  </script>
  <script src="assets/js/ui-effects.js" defer></script>
</body>
</html>
